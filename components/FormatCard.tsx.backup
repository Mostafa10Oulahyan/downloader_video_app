'use client';

import { useState } from 'react';
import { Video, Music, Copy, Check, Download, Terminal } from 'lucide-react';
import type { VideoFormat, YtDlpCommand } from '@/lib/platforms';

interface FormatCardProps {
  format: VideoFormat;
  command: YtDlpCommand;
  onCopy: (text: string) => void;
}

export function FormatCard({ format, command, onCopy }: FormatCardProps) {
  const [copied, setCopied] = useState(false);

  const handleCopy = () => {
    onCopy(command.command);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  };

  const isAudio = format.format === 'mp3';
  const Icon = isAudio ? Music : Video;

  return (
    <div
      className={`
        group relative
        bg-slate-800/50 hover:bg-slate-800/70
        border border-slate-700 hover:border-indigo-500/50
        rounded-2xl p-6
        transition-all duration-200
        cursor-pointer
      `}
      onClick={handleCopy}
    >
      {/* Quality badge */}
      <div className="flex items-center justify-between mb-4">
        <div className="flex items-center gap-3">
          {/* Format icon */}
          <div
            className={`
              w-12 h-12 rounded-xl
              flex items-center justify-center
              transition-transform duration-200 group-hover:scale-110
              ${isAudio
                ? 'bg-gradient-to-br from-purple-500/20 to-pink-500/20'
                : 'bg-gradient-to-br from-indigo-500/20 to-purple-500/20'
              }
            `}
          >
            <Icon className={`w-6 h-6 ${isAudio ? 'text-purple-400' : 'text-indigo-400'}`} />
          </div>

          {/* Quality info */}
          <div>
            <h3 className="font-semibold text-white text-lg">
              {format.quality}
            </h3>
            <p className="text-sm text-slate-400">
              {format.format.toUpperCase()}
              {format.codec && ` • ${format.codec}`}
              {format.audioBitrate && ` • ${format.audioBitrate}`}
            </p>
          </div>
        </div>

        {/* Format badge */}
        <span
          className={`
            px-3 py-1 rounded-full text-xs font-semibold
            ${isAudio
              ? 'bg-purple-500/20 text-purple-300'
              : 'bg-indigo-500/20 text-indigo-300'
            }
          `}
        >
          {format.format.toUpperCase()}
        </span>
      </div>

      {/* Command preview */}
      <div className="bg-slate-900 rounded-xl overflow-hidden mb-4">
        <div className="flex items-center gap-2 px-4 py-2 bg-slate-800/50 border-b border-slate-700">
          <Terminal className="w-4 h-4 text-slate-400" />
          <span className="text-xs text-slate-400 font-mono">yt-dlp command</span>
        </div>
        <div className="p-4 overflow-x-auto">
          <code className="text-sm text-green-400 font-mono whitespace-nowrap">
            {command.command.length > 80
              ? command.command.slice(0, 80) + '...'
              : command.command}
          </code>
        </div>
      </div>

      {/* Copy button */}
      <button
        type="button"
        onClick={(e) => {
          e.stopPropagation();
          handleCopy();
        }}
        className={`
          w-full py-3
          flex items-center justify-center gap-2
          rounded-xl font-semibold
          transition-all duration-200
          cursor-pointer
          ${copied
            ? 'bg-green-600 text-white'
            : 'bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 text-white'
          }
        `}
      >
        {copied ? (
          <>
            <Check className="w-5 h-5" />
            Copied!
          </>
        ) : (
          <>
            <Copy className="w-5 h-5" />
            Copy Command
          </>
        )}
      </button>
    </div>
  );
}

// Command Block for displaying full command
interface CommandBlockProps {
  command: YtDlpCommand;
  onCopy: (text: string) => void;
}

export function CommandBlock({ command, onCopy }: CommandBlockProps) {
  const [copied, setCopied] = useState(false);

  const handleCopy = () => {
    onCopy(command.command);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  };

  return (
    <div className="bg-slate-900 border border-slate-700 rounded-xl overflow-hidden">
      {/* Header */}
      <div className="flex items-center justify-between px-4 py-2 bg-slate-800 border-b border-slate-700">
        <div className="flex items-center gap-2">
          <Terminal className="w-4 h-4 text-green-400" />
          <span className="text-sm text-slate-300 font-medium">
            {command.description}
          </span>
        </div>
        <button
          type="button"
          onClick={handleCopy}
          className={`
            px-3 py-1 rounded-lg text-sm font-medium
            transition-colors duration-200
            cursor-pointer
            ${copied
              ? 'bg-green-600 text-white'
              : 'bg-slate-700 hover:bg-slate-600 text-slate-300'
            }
          `}
        >
          {copied ? (
            <span className="flex items-center gap-1">
              <Check className="w-3 h-3" /> Copied
            </span>
          ) : (
            <span className="flex items-center gap-1">
              <Copy className="w-3 h-3" /> Copy
            </span>
          )}
        </button>
      </div>

      {/* Command */}
      <div className="p-4 overflow-x-auto">
        <code className="text-sm text-green-400 font-mono whitespace-pre-wrap break-all">
          {command.command}
        </code>
      </div>
    </div>
  );
}

// Install instructions component
interface InstallInstructionsProps {
  instructions: { os: string; command: string; description: string }[];
  onCopy: (text: string) => void;
}

export function InstallInstructions({ instructions, onCopy }: InstallInstructionsProps) {
  const [copiedIndex, setCopiedIndex] = useState<number | null>(null);

  const handleCopy = (command: string, index: number) => {
    onCopy(command);
    setCopiedIndex(index);
    setTimeout(() => setCopiedIndex(null), 2000);
  };

  return (
    <div className="space-y-3">
      <h3 className="text-lg font-semibold text-white flex items-center gap-2">
        <Download className="w-5 h-5 text-indigo-400" />
        Install yt-dlp
      </h3>
      <div className="grid gap-2">
        {instructions.map((inst, index) => (
          <div
            key={index}
            className="flex items-center justify-between bg-slate-800/50 rounded-xl px-4 py-3 border border-slate-700"
          >
            <div>
              <span className="text-sm font-medium text-white">{inst.os}</span>
              <code className="ml-3 text-sm text-green-400 font-mono">
                {inst.command}
              </code>
            </div>
            <button
              type="button"
              onClick={() => handleCopy(inst.command, index)}
              className={`
                px-3 py-1 rounded-lg text-xs font-medium
                transition-colors duration-200
                cursor-pointer
                ${copiedIndex === index
                  ? 'bg-green-600 text-white'
                  : 'bg-slate-700 hover:bg-slate-600 text-slate-300'
                }
              `}
            >
              {copiedIndex === index ? 'Copied!' : 'Copy'}
            </button>
          </div>
        ))}
      </div>
    </div>
  );
}

export default FormatCard;
